{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: gcc.exe 生成活动文件",
            "command": "D:\\Development\\Mingw64\\x86_64-8.1.0-release-win32-seh-rt_v6-rev0\\mingw64\\bin\\gcc.exe",
            "args": [
                "-g",
                "${file}",
                "-o",
                "${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "极简编译（无冗余输出）",
            "dependsOn": ["创建build（静默）"],
            // 屏蔽编译任务的冗余终端提示
            "presentation": {
                "showReuseMessage": false
            }
        },
        // 修正：用完整命令行实现静默创建，而非拆分args
        {
            "label": "创建build（静默）",
            "type": "shell",
            // 把所有PowerShell命令写在一行，避免参数拆分错误
            "command": "New-Item -ItemType Directory -Path '${workspaceFolder}\\build' -Force | Out-Null",
            "args": [], // 清空args，避免解析错误
            "problemMatcher": [],
            // 彻底屏蔽这个任务的所有终端输出
            "presentation": {
                "echo": false,
                "reveal": "never",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false
            }
        }
    ],
    "version": "2.0.0"
}